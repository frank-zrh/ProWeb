<Window x:Class="ProWeb.Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cefwpf="clr-namespace:CefSharp.Wpf;assembly=CefSharp.Wpf"
        Title="ProWeb — Secure Cloud Browser" Height="800" Width="1200">
    <DockPanel>
        <!-- Tab strip -->
        <Grid DockPanel.Dock="Top" Height="32" Background="#ECEFF1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel x:Name="TabStripPanel" Grid.Column="0" Orientation="Horizontal" />
            <Button x:Name="NewTabButton" Grid.Column="1" Content="＋" Width="30" Margin="2"
                    AutomationProperties.Name="新建标签页" ToolTip="新建标签页 (Ctrl+T)"
                    Click="NewTabButton_Click" />
        </Grid>

        <!-- Toolbar: navigation + address bar + menu -->
        <Grid DockPanel.Dock="Top" Height="44" Background="#F3F3F3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Button x:Name="BackButton" Grid.Column="0" Content="◀" Width="36" Margin="4"
                    AutomationProperties.Name="后退" ToolTip="后退 (Alt+←)"
                    Click="BackButton_Click" />
            <Button x:Name="ForwardButton" Grid.Column="1" Content="▶" Width="36" Margin="4"
                    AutomationProperties.Name="前进" ToolTip="前进 (Alt+→)"
                    Click="ForwardButton_Click" />
            <Button x:Name="ReloadButton" Grid.Column="2" Content="⟳" Width="36" Margin="4"
                    AutomationProperties.Name="重新加载" ToolTip="重新加载 (F5)"
                    Click="ReloadButton_Click" />
            <Button x:Name="HomeButton" Grid.Column="3" Content="⌂" Width="36" Margin="4"
                    AutomationProperties.Name="主页" ToolTip="主页 (Alt+Home)"
                    Click="HomeButton_Click" />
            <StackPanel Grid.Column="4" Orientation="Vertical" Margin="4,4">
                <TextBox x:Name="AddressBar" VerticalContentAlignment="Center"
                         AutomationProperties.Name="地址栏"
                         KeyDown="AddressBar_KeyDown" TextChanged="AddressBar_TextChanged" />
                <TextBlock x:Name="AddressErrorText" Foreground="#c0392b" FontSize="11"
                           Visibility="Collapsed" Margin="2,1,0,0" />
            </StackPanel>
            <TextBlock x:Name="SecurityBadge" Grid.Column="5" Margin="8,0" VerticalAlignment="Center"
                       AutomationProperties.Name="安全状态"
                       Text="⚠ 未连接" Foreground="#b71c1c" FontWeight="Bold" />
            <Button x:Name="MenuButton" Grid.Column="6" Content="☰" Width="36" Margin="4"
                    AutomationProperties.Name="菜单" ToolTip="菜单"
                    Click="MenuButton_Click">
                <Button.ContextMenu>
                    <ContextMenu x:Name="AppMenu">
                        <MenuItem Header="新建标签页 (Ctrl+T)" Click="Menu_NewTab" />
                        <MenuItem Header="重新打开关闭的标签页 (Ctrl+Shift+T)" Click="Menu_ReopenTab" />
                        <MenuItem Header="关闭当前标签页 (Ctrl+W)" Click="Menu_CloseTab" />
                        <Separator />
                        <MenuItem Header="主页 (Alt+Home)" Click="Menu_Home" />
                        <MenuItem Header="在页面中查找… (Ctrl+F)" Click="Menu_Find" />
                        <MenuItem Header="设置 / 连接…" Click="Menu_Settings" />
                        <Separator />
                        <MenuItem x:Name="HelpMenu" Header="帮助 (Help)">
                            <MenuItem Header="键盘快捷键速查" Click="Menu_Shortcuts" />
                            <MenuItem Header="报告问题 / 反馈" Click="Menu_Feedback" />
                            <MenuItem Header="关于 ProWeb" Click="Menu_About" />
                        </MenuItem>
                    </ContextMenu>
                </Button.ContextMenu>
            </Button>
        </Grid>

        <!-- In-page find bar (Ctrl+F) -->
        <Border x:Name="FindBar" DockPanel.Dock="Top" Background="#FFFDE7" BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1" Visibility="Collapsed" Padding="6,3">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="FindInput" Width="240" VerticalContentAlignment="Center"
                         AutomationProperties.Name="页内查找" ToolTip="在页面中查找"
                         KeyDown="FindInput_KeyDown" TextChanged="FindInput_TextChanged" />
                <TextBlock x:Name="FindCount" VerticalAlignment="Center" Margin="8,0"
                           AutomationProperties.Name="查找结果计数" Foreground="#616161" />
                <Button Content="上一个" Margin="4,0,0,0" Padding="6,0"
                        AutomationProperties.Name="查找上一个" Click="FindPrev_Click" />
                <Button Content="下一个" Margin="4,0,0,0" Padding="6,0"
                        AutomationProperties.Name="查找下一个" Click="FindNext_Click" />
                <Button Content="✕" Margin="4,0,0,0" Padding="6,0"
                        AutomationProperties.Name="关闭查找 (Esc)" Click="FindClose_Click" />
            </StackPanel>
        </Border>

        <!-- Load progress -->
        <ProgressBar x:Name="LoadProgress" DockPanel.Dock="Top" Height="3"
                     IsIndeterminate="True" Visibility="Collapsed"
                     AutomationProperties.Name="加载进度" />

        <!-- Status bar -->
        <StatusBar DockPanel.Dock="Bottom" Height="24">
            <StatusBarItem>
                <TextBlock x:Name="StatusText" Text="Ready" />
            </StatusBarItem>
        </StatusBar>

        <!-- Browser surface -->
        <cefwpf:ChromiumWebBrowser x:Name="Browser" />
    </DockPanel>
</Window>
